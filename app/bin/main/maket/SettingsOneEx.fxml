<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<!--Данный файл отвечает за то чтоб, настраивать каждое отдельную тренеровку-->

<VBox fx:id="name_ex" alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="293.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mryazik.github.io.Controllers.SettingsOneEx">
   <children>
      <Label fx:id="ex_name" text="Label">
         <VBox.margin>
            <Insets bottom="20.0" />
         </VBox.margin>
      </Label>
      <VBox>
         <children>
            <Label text="Количесво подходов" />
            <TextField fx:id="count_ap" />
         </children>
         <VBox.margin>
            <Insets bottom="20.0" top="10.0" />
         </VBox.margin>
      </VBox>
      <VBox layoutX="10.0" layoutY="68.0">
         <children>
            <Label text="Количество выполнений за подход" />
            <TextField fx:id="count_comp" />
         </children>
         <VBox.margin>
            <Insets bottom="20.0" />
         </VBox.margin>
      </VBox>
      <HBox prefHeight="167.0" prefWidth="293.0">
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
         <children>
            <ImageView fx:id="image" fitHeight="150.0" fitWidth="175.0" pickOnBounds="true" preserveRatio="true">
               <HBox.margin>
                  <Insets right="30.0" />
               </HBox.margin>
               <image>
                  <Image url="@../icons/null_ex_image.png" />
               </image>
            </ImageView>
            <Button fx:id="paste_image" mnemonicParsing="false" prefWidth="88.0" text="Вставить изображение" wrapText="true" />
         </children>
      </HBox>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
         <children>
            <Button fx:id="back" mnemonicParsing="false" text="Отмена">
               <HBox.margin>
                  <Insets right="20.0" />
               </HBox.margin>
            </Button>
            <Button fx:id="done" mnemonicParsing="false" text="Готово" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="15.0" top="10.0" />
   </padding>
</VBox>
